---
import BaseLayout from '../layouts/BaseLayout.astro';

// Import data
import { siteData } from '../data/siteData';
import { businessUnits } from '../data/businessUnits';
import { useCases } from '../data/useCases';
import { processSteps } from '../data/processSteps';
import { stats } from '../data/stats';
import { differentiators } from '../data/differentiators';

// Import React components (islands)
import HeroAnimation from '../components/react/HeroAnimation';
import StatsCounter from '../components/react/StatsCounter';
import BusinessUnitCard from '../components/react/BusinessUnitCard';
import ProcessTimeline from '../components/react/ProcessTimeline';
import TestimonialCarousel from '../components/react/TestimonialCarousel';
import ContactForm from '../components/react/ContactForm';
import MobileNav from '../components/react/MobileNav';
import ScrollReveal from '../components/react/ScrollReveal';
---

<BaseLayout>
  <main id="main-content" class="relative">
    <!-- ─── Hero Section ──────────────────────────────────────────── -->
    <section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">
      {/* Canvas animation background */}
      <HeroAnimation client:load />

      {/* Hero content */}
      <div class="relative z-10 w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
        <div class="max-w-3xl">
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-text leading-tight mb-6">
            Bits, Átomos e Inteligencia:
            <span class="block text-primary mt-2">
              Conectamos tus activos con el futuro
            </span>
          </h1>
          <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mb-8 leading-relaxed">
            IoT industrial, visión artificial y software a medida — todo en un ecosistema
            que transforma datos físicos en decisiones inteligentes. Sin humo, sin vueltas.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contacto"
              class="inline-flex items-center justify-center px-8 py-4 bg-primary text-bg font-semibold rounded-lg
                hover:bg-primary/90 transition-colors text-lg"
            >
              Empezá tu proyecto
            </a>
            <a
              href="#servicios"
              class="inline-flex items-center justify-center px-8 py-4 border border-text-secondary/30 text-text font-medium rounded-lg
                hover:border-primary/50 hover:text-primary transition-colors text-lg"
            >
              Explorá servicios
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Desktop Navigation (static) ──────────────────────────── -->
    <nav class="hidden lg:block fixed top-0 left-0 right-0 z-50 bg-bg/80 backdrop-blur-md border-b border-primary/5">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="#inicio" class="text-xl font-bold text-primary">
          Janus Core
        </a>
        <div class="flex items-center gap-8">
          {siteData.navLinks.map((link) => (
            <a
              key={link.href}
              href={link.href}
              class="text-sm text-text-secondary hover:text-primary transition-colors font-medium"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- ─── Mobile Navigation (React island) ────────────────────── -->
    <div class="lg:hidden fixed top-4 right-4 z-50">
      <MobileNav client:load links={siteData.navLinks} />
    </div>

    <!-- ─── Trust Bar / Stats ────────────────────────────────────── -->
    <ScrollReveal client:visible>
      <section id="confianza" class="py-16 md:py-20 border-b border-primary/5">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <StatsCounter client:visible stats={stats} />
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── Problem Section ──────────────────────────────────────── -->
    <ScrollReveal client:visible>
      <section id="problema" class="py-20 md:py-28 border-b border-primary/5">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
            {/* Physical world */}
            <div class="text-right">
              <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
                El mundo físico
              </h2>
              <p class="text-text-secondary leading-relaxed">
                Tus máquinas, sensores y activos generan datos todo el tiempo.
                Temperatura, vibración, movimientos, accesos — señales que cuentan
                la historia de tu operación. Pero si nadie las escucha, son solo ruido.
              </p>
            </div>

            {/* Gap visual */}
            <div class="relative flex flex-col items-center py-8">
              <div class="w-px h-16 bg-gradient-to-b from-primary to-secondary" />
              <div class="my-4 w-12 h-12 rounded-full border-2 border-text-secondary/20 flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-text-secondary">
                  <path d="M12 5v14M5 12h14" strokeLinecap="round" />
                </svg>
              </div>
              <div class="w-px h-16 bg-gradient-to-b from-secondary to-accent" />
            </div>

            {/* Digital world */}
            <div>
              <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
                La inteligencia digital
              </h2>
              <p class="text-text-secondary leading-relaxed">
                Modelos de IA, dashboards y automatizaciones que podrían transformar
                tu operación. Pero sin datos del mundo real, son inteligencia sin
                contexto — teorías que no resuelven problemas concretos.
              </p>
            </div>
          </div>

          <div class="text-center mt-12">
            <p class="text-lg md:text-xl font-semibold text-primary">
              El problema no es la tecnología. Es la brecha entre ambos mundos.
            </p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── Solution Section ─────────────────────────────────────── -->
    <ScrollReveal client:visible>
      <section id="solucion" class="py-20 md:py-28 border-b border-primary/5">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">
            El puente que estabas esperando
          </h2>
          <p class="text-lg text-text-secondary max-w-2xl mx-auto mb-12 leading-relaxed">
            Janus Core es el puente entre tus activos físicos y la inteligencia digital.
            No vendemos componentes sueltos — construimos el ecosistema completo:
            desde el sensor que percibe hasta el dashboard que te muestra lo que importa.
          </p>
          <div class="grid md:grid-cols-3 gap-8">
            <div class="bg-surface rounded-xl p-6 border border-primary/10">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mx-auto mb-4">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-primary">
                  <path d="M12 2a10 10 0 1010 10" strokeLinecap="round" />
                  <path d="M12 6a6 6 0 106 6" strokeLinecap="round" />
                  <circle cx="12" cy="12" r="2" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text mb-2">Percibimos</h3>
              <p class="text-text-secondary text-sm">Sensores, cámaras y dispositivos IoT capturan cada señal de tu operación.</p>
            </div>
            <div class="bg-surface rounded-xl p-6 border border-secondary/10">
              <div class="w-12 h-12 rounded-lg bg-secondary/10 flex items-center justify-center mx-auto mb-4">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-secondary">
                  <path d="M12 3a4 4 0 00-4 4c0 1.5.5 2.5 1.5 3.5L8 16h8l-1.5-5.5C15.5 9.5 16 8.5 16 7a4 4 0 00-4-4z" />
                  <path d="M9 16v3a2 2 0 002 2h2a2 2 0 002-2v-3" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text mb-2">Procesamos</h3>
              <p class="text-text-secondary text-sm">IA local que analiza, predice y decide sin depender de la nube.</p>
            </div>
            <div class="bg-surface rounded-xl p-6 border border-accent/10">
              <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center mx-auto mb-4">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-accent">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text mb-2">Actuamos</h3>
              <p class="text-text-secondary text-sm">Dashboards, alertas y automatizaciones que cierran el círculo.</p>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── How It Works / Process Timeline ──────────────────────── -->
    <ScrollReveal client:visible>
      <section id="como-funciona" class="py-20 md:py-28 border-b border-primary/5">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl md:text-4xl font-bold text-text text-center mb-4">
            Cómo funciona
          </h2>
          <p class="text-lg text-text-secondary text-center max-w-2xl mx-auto mb-16 leading-relaxed">
            Tres pasos. Sin vueltas. Del mundo físico a la decisión inteligente.
          </p>
          <ProcessTimeline client:visible steps={processSteps} />
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── Business Units ─────────────────────────────────────────── -->
    <ScrollReveal client:visible>
      <section id="servicios" class="py-20 md:py-28 border-b border-primary/5">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl md:text-4xl font-bold text-text text-center mb-4">
            Lo que hacemos
          </h2>
          <p class="text-lg text-text-secondary text-center max-w-2xl mx-auto mb-16 leading-relaxed">
            Tres áreas de expertise que cubren todo el espectro: del sensor al software.
          </p>
          <div class="grid md:grid-cols-3 gap-6 md:gap-8">
            {businessUnits.map((unit, index) => (
              <BusinessUnitCard client:visible key={unit.id} unit={unit} index={index} />
            ))}
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── Differentiators ────────────────────────────────────────── -->
    <ScrollReveal client:visible>
      <section id="diferenciadores" class="py-20 md:py-28 border-b border-primary/5">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl md:text-4xl font-bold text-text text-center mb-4">
            Nosotros hacemos distinto
          </h2>
          <p class="text-lg text-text-secondary text-center max-w-2xl mx-auto mb-16 leading-relaxed">
            No seguimos modas. Construimos soluciones que respetan tu infraestructura, tus datos y tu plata.
          </p>
          <div class="grid md:grid-cols-3 gap-8">
            {differentiators.map((diff) => (
              <div
                key={diff.id}
                class={`bg-surface rounded-xl p-6 border ${
                  diff.highlight ? 'border-primary/30' : 'border-primary/5'
                } relative`}
              >
                {diff.highlight && (
                  <div class="absolute -top-2.5 left-4 px-2 py-0.5 bg-primary text-bg text-xs font-bold rounded">
                    PRIVACIDAD REAL
                  </div>
                )}
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-primary">
                    {diff.icon === 'shield' && (
                      <>
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                      </>
                    )}
                    {diff.icon === 'network' && (
                      <>
                        <circle cx="12" cy="4" r="2" />
                        <circle cx="4" cy="20" r="2" />
                        <circle cx="20" cy="20" r="2" />
                        <path d="M12 6v6M4 18l4-6M20 18l-4-6" />
                      </>
                    )}
                    {diff.icon === 'code' && (
                      <>
                        <polyline points="16 18 22 12 16 6" />
                        <polyline points="8 6 2 12 8 18" />
                      </>
                    )}
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-text mb-2">{diff.title}</h3>
                <p class="text-text-secondary text-sm leading-relaxed">{diff.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── Testimonials / Use Cases ───────────────────────────────── -->
    <ScrollReveal client:visible>
      <section id="casos" class="py-20 md:py-28 border-b border-primary/5">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl md:text-4xl font-bold text-text text-center mb-4">
            Casos de uso
          </h2>
          <p class="text-lg text-text-secondary text-center max-w-2xl mx-auto mb-16 leading-relaxed">
            De la teoría a la práctica. Esto es lo que ya estamos haciendo.
          </p>
          <TestimonialCarousel client:visible cases={useCases} />
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── Contact / CTA ─────────────────────────────────────────── -->
    <section id="contacto" class="py-20 md:py-28">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
          {/* CTA text */}
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">
              ¿Listo para cerrar la brecha?
            </h2>
            <p class="text-lg text-text-secondary mb-8 leading-relaxed">
              Contanos sobre tu proyecto. Te mostramos cómo conectar tus activos físicos
              con la inteligencia que los hace brillar — sin compromisos, sin vueltas.
            </p>
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-accent flex-shrink-0">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span class="text-text-secondary text-sm">Te respondemos en menos de 24 horas</span>
              </div>
              <div class="flex items-center gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-accent flex-shrink-0">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span class="text-text-secondary text-sm">Sin compromiso, sin venta agresiva</span>
              </div>
              <div class="flex items-center gap-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-accent flex-shrink-0">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span class="text-text-secondary text-sm">Propuesta personalizada para tu negocio</span>
              </div>
            </div>
          </div>

          {/* Form */}
          <div class="bg-surface border border-primary/10 rounded-xl p-6 md:p-8">
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Footer ─────────────────────────────────────────────────── -->
    <footer class="border-t border-primary/5 py-12">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
          <div>
            <a href="#inicio" class="text-xl font-bold text-primary">
              Janus Core
            </a>
            <p class="text-text-secondary text-sm mt-2">
              {siteData.tagline} &mdash; Conectamos tus activos con el futuro.
            </p>
          </div>
          <div class="flex items-center gap-6">
            {siteData.footerLinks.slice(0, 4).map((link) => (
              <a
                key={link.href}
                href={link.href}
                class="text-sm text-text-secondary hover:text-primary transition-colors"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-primary/5 text-center text-text-secondary text-xs">
          &copy; {new Date().getFullYear()} Janus Core. Todos los derechos reservados.
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
